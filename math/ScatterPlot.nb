 CellLabel->"Out[16]=",ExpressionUUID->"75aa27df-a381-4b24-b753-535bb580fba3"]
}, Open  ]],

Cell["\<\
That is it! We have obtained a data set consisting temperature/ viscosity \
data ready to be plotted.\
\>", "Text",
 CellChangeTimes->{{3.765630112735387*^9, 3.7656305460346937`*^9}, {
  3.76580655277781*^9, 3.765806555033499*^9}, {3.765824958594592*^9, 
  3.7658249939423027`*^9}, {3.765825050894631*^9, 3.7658251085665445`*^9}, {
  3.765876548891453*^9, 
  3.765876570364135*^9}},ExpressionUUID->"29587c09-74af-4623-92ed-\
7e922851c4a9"],

Cell["\<\
 Generally the common way of providing a temperature / viscosity data,  is to \
enter {temperatue, viscosity} data by hand as a sublists of the experience \
list :\
\>", "Text",
 CellChangeTimes->{{3.7658766066713066`*^9, 3.7658766090719433`*^9}, {
  3.7658767543385954`*^9, 
  3.765876806737534*^9}},ExpressionUUID->"ec9c01b0-9ec8-4cf7-8a76-\
18153cd3d167"],

