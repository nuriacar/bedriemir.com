 RowBox[{
  RowBox[{"data3", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"15", ",", "2.16"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"17", ",", "3.86"}], "}"}], ",", 
