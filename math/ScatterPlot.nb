 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"15", ",", "2.16`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"17", ",", "3.86`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"19", ",", "5.23`"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"21", ",", "6.11`"}], "}"}], ",", 
