Cell[TextData[{
 "FrameTicks \[Rule] ",
 StyleBox["{",
  FontColor->RGBColor[1, 0, 0]],
 StyleBox["{",
  FontColor->RGBColor[0., 0.615686274509804, 0.]],
 StyleBox["Left Side, Bottom",
  FontColor->GrayLevel[0]],
 StyleBox["}",
  FontColor->RGBColor[0., 0.615686274509804, 0.]],
 StyleBox[" , ",
  FontColor->GrayLevel[0]],
 StyleBox["{",
  FontColor->RGBColor[0., 0.615686274509804, 0.]],
 StyleBox["Right Side , Top",
  FontColor->GrayLevel[0]],
 StyleBox["}",
  FontColor->RGBColor[0., 0.615686274509804, 0.]],
 StyleBox["}",
  FontColor->RGBColor[1, 0, 0]]
}], "Text",
