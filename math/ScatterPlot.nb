   3.7660813861385555`*^9, 3.7670635644051623`*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"62c676fc-87a3-4b9d-8f60-00cb474df197"]
}, Open  ]],

Cell["\<\
The other way is using Mathematica\[CloseCurlyQuote]s Table [ ] function. \
This may be achieved as :\
\>", "Text",
 CellChangeTimes->{{3.765854882032539*^9, 3.7658548954158764`*^9}, {
  3.765875839599354*^9, 3.765875889025998*^9}, {3.765876326260171*^9, 
  3.7658763271046925`*^9}},ExpressionUUID->"53652ee9-b91e-4590-a10b-\
852a717673d0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"data2", " ", "=", " ", 
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"temperature", "[", 
       RowBox[{"[", "x", "]"}], "]"}], ",", 
      RowBox[{"data", "[", 
       RowBox[{"[", "x", "]"}], "]"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "1", ",", 
      RowBox[{"Length", "[", "data", "]"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.7658545413619704`*^9, 3.765854638294363*^9}, {
  3.7658546691006913`*^9, 3.7658547567084336`*^9}, {3.7658548225276747`*^9, 
  3.765854853591854*^9}, {3.7658736423718367`*^9, 3.76587367583664*^9}, {
  3.765876477697296*^9, 3.7658764848621845`*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"f7ae7970-8651-4b57-b04d-27af6a6f1f54"],

