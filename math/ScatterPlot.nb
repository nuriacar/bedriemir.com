 GraphicsBox[{{}, {{}, 
    {RGBColor[0.368417, 0.506779, 0.709798], PointSize[0.012833333333333334`],
      AbsoluteThickness[1.6], 
     PointBox[{{1., 2.16}, {2., 3.86}, {3., 5.23}, {4., 6.11}, {5., 7.82}, {
      6., 9.28}, {7., 13.88}, {8., 23.77}, {9., 
