      RowBox[{"19", ",", "5.23"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"21", ",", "6.11"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"23", ",", "7.82"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"25", ",", "9.28"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"27", ",", "13.88"}], "}"}], ",", 
     RowBox[{"{", 
