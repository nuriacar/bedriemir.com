   3.7656300628850093`*^9, 3.765639887303585*^9, 3.765695704059929*^9, 
   3.7658166141805215`*^9, 3.765825799074421*^9, 3.765853245975614*^9, 
   3.7658562717443027`*^9, 3.765856323766459*^9, 3.7658579162141447`*^9, 
