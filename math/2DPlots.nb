31ecfd3e0717"],

Cell[TextData[{
 "Find whether the function y = ",
 Cell[BoxData[
  SuperscriptBox["3", 
   FractionBox["x", 
    RowBox[{"1", "-", 
     SuperscriptBox["x", "2"]}]]]],
  CellChangeTimes->{{3.7661907066161795`*^9, 3.7661907548711667`*^9}},
  ExpressionUUID->"8b12a400-5596-4a3b-b136-e8f10f35c220"],
