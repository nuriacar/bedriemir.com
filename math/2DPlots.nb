Cell[CellGroupData[{

Cell["Example", "Subsubsection",
 CellChangeTimes->{{3.766498949909463*^9, 
  3.7664989541813164`*^9}},ExpressionUUID->"f15391b4-f9c7-4b18-9aff-\
d840a2b43797"],

Cell[TextData[{
 "Find the points of discontinuity of the function f(x) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"=", 
    FractionBox[
     RowBox[{"|", 
      RowBox[{
       RowBox[{"2", "x"}], " ", "+", " ", "5"}], "|"}], 
     RowBox[{
      RowBox[{"2", "x"}], " ", "+", " ", "5"}]]}], TraditionalForm]],
  ExpressionUUID->"dfdc4d64-3b54-462d-9ef5-0e2b24f19433"]
}], "Text",
 CellChangeTimes->{{3.7662752909776363`*^9, 
  3.766275422019594*^9}},ExpressionUUID->"04cf6bfb-8ceb-4c5e-ac92-\
50a50f07782c"],

Cell["The point of discontinuity :", "Text",
 CellChangeTimes->{{3.766275473150326*^9, 
  3.7662755048051996`*^9}},ExpressionUUID->"d4b3cf45-e300-4bef-bd0b-\
895354cc2417"],

Cell[BoxData[{
 RowBox[{"Clear", "[", 
  RowBox[{"f", ",", "x"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"f", "[", "x_", "]"}], ":=", " ", 
  FractionBox[
   RowBox[{"Abs", "[", 
    RowBox[{
     RowBox[{"2", "x"}], "+", "5"}], "]"}], 
   RowBox[{
    RowBox[{"2", " ", "x"}], " ", "+", "5"}]]}]}], "Input",
 CellChangeTimes->{{3.766378567970726*^9, 3.766378575991146*^9}, {
