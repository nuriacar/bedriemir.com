  ExpressionUUID->"92ba644b-f0a4-4c02-84af-9c0c7624b362"],
 "."
}], "Text",
 CellChangeTimes->{{3.7664794923714905`*^9, 
  3.7664795519131517`*^9}},ExpressionUUID->"e2eb7485-2676-4d61-937f-\
4da65ad501ec"],

