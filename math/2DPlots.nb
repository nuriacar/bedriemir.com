 RowBox[{"{", 
  RowBox[{
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"ArcTan", "[", 
      FractionBox["1", "x"], "]"}], ",", " ", 
     RowBox[{"x", "\[Rule]", " ", 
      RowBox[{"0", "-", "0"}]}]}], "]"}], ",", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"ArcTan", "[", 
      FractionBox["1", "x"], "]"}], ",", " ", 
