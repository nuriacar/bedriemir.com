Cell["\<\
The plot of this function is nothing than a seamless plotting of both pieces \
separately but contigiously due to the sophisticated intricate plotting \
function of Mathematica, which plot the first order class A functions aa a \
single graph whose discontinuities can not be noticed by eyes. Even adding \
the option ``Exclusions\[Rule]None\[CloseCurlyDoubleQuote] will not help for \
having the exlusion point be inserted within the graph.\
\>", "Text",
 CellChangeTimes->{{3.7664936953698874`*^9, 3.7664940315512047`*^9}, {
   3.766495132451095*^9, 3.76649518288362*^9}, {3.766925487911069*^9, 
   3.7669254916619453`*^9}, {3.766925533566066*^9, 3.7669256910303802`*^9}, {
   3.7670204483463097`*^9, 3.7670204664939528`*^9}, 
   3.7670205090266824`*^9},ExpressionUUID->"d6108a43-e912-4b87-a17e-\
cd58f6bb4bef"],

Cell[TextData[{
 "Mathematica has a Piecewise[ ] function but this function is most useful in \
function having jump discontinuities and essential discontinuities . For \
function plotting,  simple Plot [ ] function will suffice, with or without \
``Exclusions\[Rule]None",
 StyleBox["\[CloseCurlyDoubleQuote] ",
  FontWeight->"Bold"],
 "option. Note that for the functions having first order class A \
discontinuities stating Exclusions\[Rule] All is unnecessary."
}], "Text",
 CellChangeTimes->{{3.7664941042099094`*^9, 3.7664943419665265`*^9}, {
  3.7669257070742416`*^9, 3.7669257087302976`*^9}, {3.766925743918268*^9, 
  3.7669259454754653`*^9}},ExpressionUUID->"c5a56949-5796-4605-8830-\
264b47b80f89"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], ",", 
        RowBox[{"x", "<", "1"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], ",", " ", 
        RowBox[{"x", ">", "1"}]}], "}"}]}], "}"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", " ", 
     RowBox[{
      RowBox[{"-", "2"}], "\[Pi]"}], ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}], ",", 
   RowBox[{"Exclusions", "\[Rule]", 
    RowBox[{"{", "1", "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Ticks", "\[Rule]", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], "\[Pi]"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "3"}], "/", "2"}], "  ", "\[Pi]"}], ",", 
        RowBox[{"-", "\[Pi]"}], ",", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], "  ", "\[Pi]"}], ",", "  ", 
        RowBox[{
         RowBox[{"1", "/", "2"}], "\[Pi]"}], ",", "\[Pi]", ",", 
        RowBox[{
         RowBox[{"3", "/", "2"}], "\[Pi]"}]}], "}"}], ",", "Automatic"}], 
     "}"}]}], ",", 
   RowBox[{"ImageSize", "\[Rule]", "500"}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.7661954208914957`*^9, 3.7661954741860943`*^9}, {
   3.766195690484056*^9, 3.766195700993328*^9}, {3.766236964173374*^9, 
