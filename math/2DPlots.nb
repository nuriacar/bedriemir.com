Cell["\<\
Adding Piecewise[ ] function is not enhancing the graph compared to the graph \
produced by a simple Plot [ ] function.\
\>", "Text",
 CellChangeTimes->{{3.766494411045257*^9, 3.766494503454913*^9}, {
  3.7664950259505577`*^9, 3.7664950458392177`*^9}, {3.7667196264454055`*^9, 
  3.766719644247617*^9}},ExpressionUUID->"c0121815-7d0c-4657-8e78-\
3d1b2afe1030"],

Cell["\<\
This function has a removable discontinuity at at x=0. This cannot be seen in \
graphs and even Mathematica does not help. The discontinuity may only be \
understood by finding the value of the independent variable (x) which makes \
the value of the function ``Unknown\[CloseCurlyDoubleQuote] and this value is \
conventionally considered as ``Infinity\[CloseCurlyDoubleQuote] (\[Infinity]) \
. \
\>", "Text",
 CellChangeTimes->{{3.766197001804993*^9, 3.7661970680925026`*^9}, {
  3.7662187569844685`*^9, 3.7662189991930237`*^9}, {3.7662191302733517`*^9, 
  3.7662191336452537`*^9}, {3.7667196570780945`*^9, 3.766719658453472*^9}, {
  3.7667196948581448`*^9, 3.7667196965771904`*^9}, {3.7668989545546074`*^9, 
  3.7668990643486223`*^9}},ExpressionUUID->"0def33f4-ad26-4f18-99c2-\
1ea750a217b7"],

Cell[TextData[{
 "The function ",
 Cell[BoxData[
  RowBox[{" ", 
   FractionBox[
    RowBox[{"Sin", "[", "x", "]"}], "x"]}]],
  CellChangeTimes->{{3.7661948525920286`*^9, 3.7661948573390102`*^9}, {
   3.7661953138503933`*^9, 3.76619531583801*^9}, {3.7661953889733524`*^9, 
   3.766195405966626*^9}, {3.7661955245528593`*^9, 3.7661955255985575`*^9}},
  ExpressionUUID->"bc6ec7f4-05e5-4251-b28e-b757c1588234"],
 " ,  for x = 0, has a limit conventionally equal to infinity (whatever the \
meaning is) and in this value of free variable, the  left and right limits \
are numeric and equal to each other."
}], "Text",
 CellChangeTimes->{{3.766219356224392*^9, 3.7662195124932423`*^9}, 
   3.7662195669497995`*^9, {3.766899080950139*^9, 
   3.7668993059560375`*^9}},ExpressionUUID->"5511d5b4-bbd1-493a-bf97-\
7a9705ab7d4a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Limit", "[", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"Sin", "[", "x", "]"}], "x"], ",", 
     RowBox[{"x", "\[Rule]", " ", 
      RowBox[{"0", "-", "0"}]}]}], "]"}], ",", 
   RowBox[{"Limit", "[", " ", 
    RowBox[{
     FractionBox[
      RowBox[{"Sin", "[", "x", "]"}], "x"], ",", 
     RowBox[{"x", "\[Rule]", " ", 
      RowBox[{"0", "+", "0"}]}]}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.7662195740501547`*^9, 3.766219666946262*^9}},
 CellLabel->"In[84]:=",ExpressionUUID->"4c86ce70-7d81-4276-9ae6-d3ddd847fa39"],

Cell[BoxData[
