Cell["\<\
Manipulations can only be active in Mathematica notebook files (*.nb). For \
publishing the notebooks contianing manipulations, one must publish them as \
(*.cdf) instead of [*.html or *.htm] or (*.pdf). The cdf reader is free and \
may be downloaded freely from Wolfram website. When published with other \
formats, manipulations may be observed but can not be manipulated.\
\>", "Text",
 CellChangeTimes->{{3.7659616895424566`*^9, 3.7659621003308477`*^9}, {
  3.766838644886469*^9, 
  3.7668386491218643`*^9}},ExpressionUUID->"a7011a6b-23a8-4522-9638-\
399943be9d22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Options", "Subsection",
 CellChangeTimes->{{3.765982759382069*^9, 
  3.765982767400875*^9}},ExpressionUUID->"faedab8e-5353-4082-b0a8-\
e9cdb278910c"],

Cell["\<\
Plots may be enhanced using various options. Mahematica offers a multitude \
options that can be implemented by the user. Bu the vaste number of these \
options make them very difficult to master all of these. The compromise is \
choosing from the options the ones that more generally applied to most \
instances of function plotting.\
\>", "Text",
 CellChangeTimes->{{3.765982774741136*^9, 3.765982823550242*^9}, {
  3.7659848195202713`*^9, 3.7659849311223464`*^9}, {3.7659849895525084`*^9, 
  3.7659851428690157`*^9}},ExpressionUUID->"d8308512-6f14-4cc3-9eb0-\
74e6e801e72c"],

Cell[CellGroupData[{

Cell["Frames", "Subsubsection",
 CellChangeTimes->{{3.765993228652521*^9, 
  3.76599325493448*^9}},ExpressionUUID->"5f695bf4-0b99-42a0-b6e4-\
62b723aefc05"],

Cell["\<\
Plots in Mathematica are better shown by incorporating within a frame. Frames \
for plots are defined as :\
\>", "Text",
 CellChangeTimes->{{3.76599326825086*^9, 
  3.765993349142602*^9}},ExpressionUUID->"7257fc85-bf2e-42b2-830a-\
cf93411c53d2"],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  TemplateBox[{Cell[
     TextData["Graphics"]],"paclet:ref/Graphics"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f9ff6dfd-d246-4548-812f-9424afed4029"],
 ", ",
 Cell[BoxData[
  TemplateBox[{Cell[
     TextData["Plot"]],"paclet:ref/Plot"},
   "RefLink",
   BaseStyle->{"InlineFormula"}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1e02e597-66ba-4efa-aebe-6642891df73d"],
 ", and related functions, ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["Frame"]],"paclet:ref/Frame"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "->", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       StyleBox["left", "TI"], ",", 
       StyleBox["right", "TI"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       StyleBox["bottom", "TI"], ",", 
       StyleBox["top", "TI"]}], "}"}]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0abd50fe-4dc8-4ddc-9268-4d32d64b532a"],
 " specifies whether to draw a frame on each edge. With the default setting ",
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["FrameTicks"]],"paclet:ref/FrameTicks"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "->", 
   TemplateBox[{Cell[
      TextData["Automatic"]],"paclet:ref/Automatic"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f57951db-b07c-4037-8a99-2694ab63debf"],
 ", ticks are included whenever a frame is drawn."
}], "Text",
 CellChangeTimes->{
  3.7659933561106033`*^9},ExpressionUUID->"ae1a42bf-24a0-43af-b8e3-\
d7ced2b98f8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f1", "[", "x_", "]"}], ":=", 
    RowBox[{"x", " ", 
     RowBox[{"Exp", "[", "x", "]"}]}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"University", " ", "of", " ", "Texas", " ", "in", " ", "Austin"}], 
   " ", "*)"}]}]], "Input",
 CellChangeTimes->{{3.7659934135737133`*^9, 3.76599348165874*^9}, {
  3.765993552400259*^9, 3.765993593619671*^9}, {3.7659936364281745`*^9, 
  3.765993664295227*^9}, {3.7659937960448327`*^9, 3.765993806924609*^9}, {
  3.766753317075138*^9, 3.7667533589193025`*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"9ae2bec8-2c93-429d-8d48-5d5e9583441d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"f1", "[", "x", "]"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "2"}], ",", "5"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Frame", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"True", ",", "False"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"FrameTicks", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"True", ",", "False"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"True", ",", "False"}], "}"}]}], "}"}]}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Axes", "\[Rule]", " ", "None"}]}], " ", "\[IndentingNewLine]", 
  "]"}]], "Input",
 CellChangeTimes->{{3.765993486638889*^9, 3.7659935355918765`*^9}, {
   3.765993608681052*^9, 3.765993621387781*^9}, {3.765993830648033*^9, 
