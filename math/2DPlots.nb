Cell[CellGroupData[{

Cell["Plots of Predefined Functions", "Subsubsection",
 CellChangeTimes->{{3.76588905617938*^9, 
  3.7658890778849154`*^9}},ExpressionUUID->"6ee5a32c-1ca2-47b9-9a95-\
15234e18f818"],

Cell["\<\
Sin[x] and Cos[x] are predefined functions. They can be readily plotted using \
prede\[LineSeparator]fined function Plot [ ],
Plot [function [free (independent) Variable] , {free (independent) Variable , \
initialValue , finalValue , options (if there is any)}]\
\>", "Text",
 CellChangeTimes->{{3.765887950795493*^9, 3.7658879816997647`*^9}, {
  3.765888047927786*^9, 3.765888132287386*^9}, {3.7658881798870697`*^9, 
  3.765888275367296*^9}, {3.7658883270706415`*^9, 3.7658883867863894`*^9}, {
  3.7669026939702215`*^9, 
  3.7669028235238504`*^9}},ExpressionUUID->"e6971d2e-20f1-4146-9ab8-\
82a099cd761f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p1", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Sin", "[", "x", "]"}], ",", 
