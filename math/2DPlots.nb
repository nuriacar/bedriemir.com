Cell["\<\
For the final result, the given function is determined to have essential, \
nonremovable second class discontinuities at the points x = -1 and x =1. This \
is supporting by mathematical anaysis and by the results obtained from \
graphical investigations.\
\>", "Text",
 CellChangeTimes->{{3.7661920994917192`*^9, 3.7661923321176124`*^9}, {
  3.766192405386118*^9, 3.7661924217100554`*^9}, {3.7663124069543467`*^9, 
  3.7663124191383705`*^9}, {3.7663779111458488`*^9, 3.7663779150296297`*^9}, {
  3.7664787666765575`*^9, 3.766478840744618*^9}, {3.76692531821673*^9, 
  3.7669254056849413`*^9}, {3.7669290525858607`*^9, 3.766929064698958*^9}, {
  3.766970182916359*^9, 3.766970243114064*^9}, {3.7669702817393537`*^9, 
  3.7669702926565*^9}},ExpressionUUID->"ac94c912-a4a6-420f-9fe2-42ac97517b68"]
}, Open  ]],

