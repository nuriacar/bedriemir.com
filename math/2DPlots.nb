Cell["\<\
Manipulations is changing some value affecting the function definition bzw. \
the plot of the function by mouse.\
\>", "Text",
 CellChangeTimes->{{3.7659611545290103`*^9, 
  3.7659612777616367`*^9}},ExpressionUUID->"ecd6d3cd-3eac-4dbe-86c0-\
8b58e44f9aab"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"expression", 
      RowBox[{"(", "u", ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", 
       SubscriptBox["u", "min"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "5a36d14a-0385-423b-b079-fea15cdf2356"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "max"], TraditionalForm]],ExpressionUUID->
  "6af073e2-6d2f-47e5-96a9-e03aadd609d7"],
 "}] (*  u any value between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "min"], TraditionalForm]],ExpressionUUID->
  "27f0ed47-7d67-43e2-9df5-8e4d568570c0"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "max"], TraditionalForm]],ExpressionUUID->
  "14d6ccd3-238f-4ed0-afac-a2b2d354953a"],
 " *)"
}], "Text",
 CellChangeTimes->{{3.7622593695693474`*^9, 
  3.762259679892967*^9}},ExpressionUUID->"503b0e49-6549-4c36-b056-\
9940ea1ff1b4"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{"Manipulate", "[", 
    RowBox[{
     RowBox[{"expression", 
      RowBox[{"(", "u", ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"u", ",", 
       SubscriptBox["u", "min"]}]}]}]}], TraditionalForm]],ExpressionUUID->
  "56f3f3e7-e268-40a0-b493-7716d8e910bc"],
 ",",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["u", "max"], ",", "dt"}], TraditionalForm]],ExpressionUUID->
  "e343cdc6-a47d-4168-93af-3a892844f7cb"],
 "}] (*  u any value between ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "min"], TraditionalForm]],ExpressionUUID->
  "c7b24126-b13f-4974-918a-9932742ed9af"],
 ",",
 Cell[BoxData[
  FormBox[
   SubscriptBox["u", "max"], TraditionalForm]],ExpressionUUID->
  "51895396-f7bc-4ebd-b3bf-c6f2dba1f58e"],
