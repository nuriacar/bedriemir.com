Cell["\<\
It is better, to define user defined functions as f[independentVariable_] : = \
Expression having one independentVariable declared in the definition of the \
function. \
\>", "Text",
 CellChangeTimes->{{3.765907195797127*^9, 3.765907421138815*^9}, {
  3.765907607722777*^9, 3.7659076694833465`*^9}, {3.7668383648457327`*^9, 
  3.766838365784446*^9}, {3.7669029568292675`*^9, 
  3.7669030606897173`*^9}},ExpressionUUID->"81480435-db1a-4fc8-86fc-\
362be685d3ee"],

