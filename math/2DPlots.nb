Cell["About Dashing,", "Text",
 CellChangeTimes->{{3.766570743171142*^9, 
  3.7665707724793406`*^9}},ExpressionUUID->"cc4078f2-a251-4a5d-997e-\
36a00853ffaa"],

Cell[TextData[{
 "Dashing is a very advanced plot option for every distinguished plotted \
curves.\nDashing may be ",
 StyleBox["{",
  FontSize->40],
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{" ", 
       RowBox[{"Absolute", " ", 
        RowBox[{"(", 
         RowBox[{
         "not", " ", "dependent", " ", "to", " ", "image", " ", "size"}], 
         ")"}], " "}]}]},
     {
      RowBox[{" ", 
       RowBox[{"Relative", " ", 
        RowBox[{"(", 
         RowBox[{"dependent", " ", "to", " ", "image", " ", "size"}], ")"}], 
        "           "}]}]}
    }], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->"cd245cd2-6953-4992-9924-0c69715ac609"]
}], "Text",
 CellChangeTimes->{{3.7665707819548955`*^9, 3.7665710601663194`*^9}, {
  3.766571126663172*^9, 3.766571150298625*^9}, {3.7665717544180937`*^9, 
  3.766571766873966*^9}},ExpressionUUID->"d91a0032-162b-4b39-96ee-\
12ddb02a335d"],

Cell["\<\
Dashing is evaluated as succession of {trace,leaveBlank} successions. If they \
are equally spaced, giving only one measure will suffice as Dashing[Tiny].\
\>", "Text",
 CellChangeTimes->{{3.7665712844866548`*^9, 3.766571509149779*^9}, {
  3.7665718000099516`*^9, 
  3.7665718268855267`*^9}},ExpressionUUID->"44c2e8dd-a661-4398-a2fe-\
7a5573e81436"],

Cell[TextData[{
 "Dashing may be given as  ",
 StyleBox["{",
  FontSize->40],
 Cell[BoxData[
  FormBox[GridBox[{
     {
      RowBox[{" ", 
       RowBox[{"Absolute", " ", "Measures", " ", 
        RowBox[{"(", 
         RowBox[{"Tiny", ",", "Medium", ",", "Large"}], ")"}], 
        "                   "}]}]},
     {
      RowBox[{" ", 
       RowBox[{"Relative", " ", "Numbers", " ", 
        RowBox[{"(", 
         RowBox[{
         "fractions", " ", "of", " ", "the", " ", "image", " ", "size"}], 
         ")"}], "           "}]}]}
    }], TraditionalForm]],
  TextAlignment->Center,ExpressionUUID->"b1b48420-a982-42ba-b911-0552e6bab5ef"]
}], "Text",
 CellChangeTimes->{{3.7665715756256475`*^9, 3.7665717316381598`*^9}, {
  3.766571849541531*^9, 
  3.7665718534692783`*^9}},ExpressionUUID->"df191d4c-d064-4f3f-b32b-\
fcbec8dd9035"],

Cell["\<\
Dashing[{}] means, no dash, just a solid curve as evaluated by default, \
therefore there is no need to state.\
\>", "Text",
 CellChangeTimes->{{3.7665718934473467`*^9, 
  3.7665719795409636`*^9}},ExpressionUUID->"fc00545b-7697-4854-afbd-\
a76beadcc81b"],

Cell["Adding PlotStyle,", "Text",
 CellChangeTimes->{{3.766572008360433*^9, 
  3.766572019644966*^9}},ExpressionUUID->"9dac49f1-505c-4516-bc93-\
c0eb8d79825a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p1", " ", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Tooltip", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Sin", "[", "x", "]"}], ",", 
       RowBox[{"Cos", "[", "x", "]"}]}], "}"}], "]"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{
       RowBox[{"-", "2"}], "\[Pi]"}], ",", 
      RowBox[{"2", "\[Pi]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRegion", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "2"}], "Pi"}], ",", 
       RowBox[{"2", "Pi"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "1"}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotStyle", "\[Rule]", 
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.0008", "]"}], ",", 
         RowBox[{"Dashing", "[", 
          RowBox[{"{", "}"}], "]"}], ",", 
         RowBox[{"RGBColor", "[", 
          RowBox[{"0.12", ",", "0.32", ",", "0.62"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Thickness", "[", "0.001", "]"}], ",", 
         RowBox[{"Dashing", "[", 
          RowBox[{"{", 
           RowBox[{"0.01", ",", "0.02"}], "}"}], "]"}], ",", 
         RowBox[{"RGBColor", "[", 
          RowBox[{"0.89", ",", "0.34", ",", "0.36"}], "]"}]}], "}"}]}], 
      "\[IndentingNewLine]", "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
