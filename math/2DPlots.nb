Cell[TextData[{
 "Clearly, the function ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{"x", "-", "1"}]], TraditionalForm]],ExpressionUUID->
  "9bd3ac8f-bce9-4d4f-adea-03c95a7f56af"],
 " has a vertical asymptote, normal to the x axis at point {1 , 0} indicated \
by the graph of the function. But we must always find the exact values by \
mathematical methods."
}], "Text",
 CellChangeTimes->{{3.766167091854377*^9, 3.7661672472667084`*^9}, {
   3.7664759850362825`*^9, 3.766476064587062*^9}, 
   3.766889985084634*^9},ExpressionUUID->"4b5bddcb-a636-4376-a487-\
2d4d8198f7b6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "-", "1"}], "\[Equal]", "0"}], ",", 
   RowBox[{"{", "x", "}"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.766167020458197*^9, 3.76616706015903*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"d72bf4b7-4cd4-49aa-8279-4d7ed98b61be"],

