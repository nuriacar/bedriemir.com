  3.766479473823655*^9}},ExpressionUUID->"f1a05b79-69f1-49a6-8d3d-\
6b86313bff15"],

Cell[TextData[{
 "Find the discontinuities of the function y = ",
 Cell[BoxData[
  FractionBox[
   RowBox[{"Sin", "[", "x", "]"}], "x"]],
  CellChangeTimes->{{3.7661948525920286`*^9, 3.7661948573390102`*^9}, {
