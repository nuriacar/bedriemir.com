 RowBox[{
  RowBox[{
   RowBox[{"g", "[", "x_", "]"}], ":=", " ", 
   RowBox[{"2", " ", 
    SuperscriptBox["x", "2"], " ", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", "x"}], "]"}], 
    RowBox[{"Sin", "[", "x", "]"}]}]}], " ", ";"}]], "Input",
