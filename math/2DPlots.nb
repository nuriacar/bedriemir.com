Cell["\<\
FrameLabel \[Rule] rule may be applied for labeling the edges of the frame \
with style.\
\>", "Text",
 CellChangeTimes->{{3.766059821725092*^9, 3.766059870825034*^9}, {
  3.767017092397152*^9, 
  3.767017215728988*^9}},ExpressionUUID->"33ec238b-7f3d-44a0-bf31-\
49bfc487e729"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["FrameLabel"]],"paclet:ref/FrameLabel"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   TemplateBox[{Cell[
      TextData["None"]],"paclet:ref/None"},
    "RefLink",
    BaseStyle->{"InlineFormula"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "301eee27-d2ca-4c2b-8add-64089f450db9"],
 " specifies that no labels should be given. "
}], "Text",
 CellChangeTimes->{{3.7660598879248915`*^9, 3.766059924875013*^9}, {
  3.7670172286082363`*^9, 
  3.7670172286082363`*^9}},ExpressionUUID->"4a7787dd-78af-4d49-8f93-\
eddff4ffd936"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["FrameLabel"]],"paclet:ref/FrameLabel"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   StyleBox["label", "TI"]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6f1ca3d6-7917-4974-a6b2-00be26609916"],
 " specifies a label for the bottom edge of the frame. "
}], "Text",
 CellChangeTimes->{
  3.7660599448611913`*^9, {3.767017234095057*^9, 
   3.767017234095057*^9}},ExpressionUUID->"84d512e2-e15c-469c-b1a3-\
16be213aad79"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["FrameLabel"]],"paclet:ref/FrameLabel"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{
     StyleBox["bottom", "TI"], ",", 
     StyleBox["left", "TI"]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c225475c-2132-48fb-a5f2-cfd8fa93f4ff"],
 " specifies labels for the bottom and left\[Hyphen]hand edges of the frame. "
}], "Text",
 CellChangeTimes->{
  3.766059972443554*^9, {3.7670172392262135`*^9, 
   3.7670172392262135`*^9}},ExpressionUUID->"5113aaed-9a5b-44fa-a1dd-\
89dccb9287d3"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   TemplateBox[{Cell[
      TextData["FrameLabel"]],"paclet:ref/FrameLabel"},
    "RefLink",
    BaseStyle->{"InlineFormula"}], "\[Rule]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       StyleBox["left", "TI"], ",", 
       StyleBox["right", "TI"]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       StyleBox["bottom", "TI"], ",", 
       StyleBox["top", "TI"]}], "}"}]}], "}"}]}]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "770ed0a7-6f0d-4fac-a7dd-253686bab78c"],
 " specifies labels for each of the edges of the frame. "
}], "Text",
 CellChangeTimes->{
  3.7660599955808587`*^9, {3.767017243774724*^9, 
   3.767017243774724*^9}},ExpressionUUID->"a472bac8-b3a3-458c-a1d9-\
18e9038dae0b"],

Cell[TextData[{
 "Any expression can be specified as a label. It will be given by default in ",
 Cell[BoxData[
  TemplateBox[{Cell[
