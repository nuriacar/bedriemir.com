Cell[CellGroupData[{

Cell["Functions Plotted Together", "Subsection",
 CellChangeTimes->{{3.766499288476071*^9, 
  3.766499317239533*^9}},ExpressionUUID->"ee3016ce-d62d-4a53-bc8b-\
80741f175ce7"],

Cell["\<\
Plotting functions together makes only sense if these functions share common \
domain of the common independent variable and give about the comparable \
values in the range of the dependent variable. Best examples may be sinus and \
cosinus functions.\
\>", "Text",
 CellChangeTimes->{{3.7664993281067114`*^9, 3.7664995744006586`*^9}, {
  3.766980402918722*^9, 
  3.7669804084965525`*^9}},ExpressionUUID->"6b9ae8d1-122d-43de-b25d-\
36a84a702344"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Sin", "[", "x", "]"}], ",", 
     RowBox[{"Cos", "[", "x", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", 
     RowBox[{
      RowBox[{"-", "2"}], "\[Pi]"}], ",", 
     RowBox[{"2", "\[Pi]"}]}], "}"}]}], "]"}]], "Input",
