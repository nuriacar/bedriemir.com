Cell["\<\
 More precise locations of aymptotic lines, are to be found by mathematical \
analysis.\
\>", "Text",
 CellChangeTimes->{{3.766675755340864*^9, 
  3.76667578755239*^9}},ExpressionUUID->"7473446a-7236-4781-8ead-\
b430bc785773"],

Cell[TextData[{
 "The function structure is of type ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "a"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "38282af1-28a7-44f9-a7bc-1a74d6e1d544"],
 " and indeterminable when ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["n", "indeterminate"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "7f86bd76-724b-40d9-bda9-ed3247fcb5d6"],
 ". We will look for an x which will cause, ",
 Cell[BoxData[
  FormBox[
   FractionBox["x", 
    RowBox[{"1", "-", 
     SuperscriptBox["x", "2"]}]], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "013e3431-f3b4-4ab7-8cf0-384c3fcbced9"],
 " indeterminate. Let  us simplify this rational expression."
}], "Text",
 CellChangeTimes->{{3.7669279178670464`*^9, 3.766928091331249*^9}, {
  3.766928129236658*^9, 
  3.766928193868846*^9}},ExpressionUUID->"55e4262c-8a34-4ad2-88cd-\
a458ece92789"],

Cell[TextData[{
 Cell[BoxData[
  FractionBox[
   FractionBox["x", "x"], 
   FractionBox[
    RowBox[{"1", "-", 
     SuperscriptBox["x", "2"]}], "x"]]], "Input",
  CellChangeTimes->{{3.7669283233451*^9, 3.766928450850477*^9}},
  FontSize->30,ExpressionUUID->"e0500de7-7336-4b85-adfa-978461d42a37"],
 StyleBox[" = ",
  FontSize->30],
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    FractionBox[
     RowBox[{"1", "-", 
      SuperscriptBox["x", "2"]}], "x"]], TraditionalForm]],
  FontSize->30,ExpressionUUID->"882fd816-b5eb-4c12-b03a-8c446f34158c"],
 StyleBox["= ",
  FontSize->30],
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{
     FractionBox["1", "x"], "-", "x"}]], TraditionalForm]],
  FontSize->30,ExpressionUUID->"da51ca89-5b5f-4e12-bbe7-b2e440e98585"]
}], "Text",
 CellChangeTimes->{{3.7669285249483824`*^9, 
  3.766928605047775*^9}},ExpressionUUID->"580abd39-6e25-4578-8445-\
ec4216f8f559"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    FractionBox["1", "x"], "-", "x"}], " ", "=", "0"}], ";", " ", 
  RowBox[{
   FractionBox["1", "x"], " ", "=", " ", "x"}], " ", ";", "  ", 
  RowBox[{
   SuperscriptBox["x", "2"], " ", "=", " ", "1"}], " ", ";", " ", 
  RowBox[{
   SqrtBox[
    SuperscriptBox["x", "2"]], " ", "=", " ", "1"}], " ", ";", 
  RowBox[{"x", "=", 
   RowBox[{
    RowBox[{"1", " ", "or", " ", "x"}], "=", 
    RowBox[{"-", "1"}]}]}]}]], "Text",
 CellChangeTimes->{{3.766941979595071*^9, 3.7669420996946545`*^9}, {
  3.766969857945403*^9, 3.7669699063594246`*^9}, {3.7669699379343386`*^9, 
  3.766969952200039*^9}},ExpressionUUID->"d133ecc8-c6b7-4f79-86b5-\
4a811c25ba01"],

Cell["or,", "Text",
 CellChangeTimes->{{3.7669699621855173`*^9, 
  3.766969966218012*^9}},ExpressionUUID->"5dbdd483-e779-4934-b2a1-\
d90a2d29c0d7"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   FractionBox[
    FractionBox["1", "x"], "x"], TraditionalForm]],ExpressionUUID->
  "a4c9ba2f-1bd1-46d3-ad8e-16c7740f4091"],
 "= 0 ; ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    SuperscriptBox["x", "2"]], TraditionalForm]],ExpressionUUID->
  "920bb6c4-7ae1-45d8-9076-9f79199f3342"],
 " = 0 ; ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "a8a4d840-2774-4c8b-91c7-87faa51b5054"],
 " = 1 ; ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "1c4a1899-6201-4e90-84cb-331b22205571"],
 " - 1 = 0 ; (x-1)(x+1) = 0; x = 1 or x = -1"
}], "Text",
 CellChangeTimes->{{3.766942123905864*^9, 3.7669422178443704`*^9}, {
  3.7669422505297437`*^9, 3.766942271081051*^9}, {3.766942317709493*^9, 
  3.766942375553534*^9}},ExpressionUUID->"71fbfdec-4892-46a0-b4b2-\
1f1215c258cc"],

Cell["or simply", "Text",
 CellChangeTimes->{{3.7669423893936505`*^9, 
  3.7669423931695127`*^9}},ExpressionUUID->"dcf63323-ea29-4e0c-a308-\
6fd9232f69e5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     FractionBox["1", "x"], "-", "x"}], " ", "\[Equal]", " ", "0"}], ",", " ",
    "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.7669277707708273`*^9, 3.766927845761116*^9}, {
  3.7669286344879913`*^9, 3.7669286519030724`*^9}, {3.7669700198460817`*^9, 
  3.766970026892716*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"9b444271-237c-47dd-990b-7601e084d901"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", 
     RowBox[{"-", "1"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"x", "\[Rule]", "1"}], "}"}]}], "}"}]], "Output",
 CellChangeTimes->{{3.7669278258404713`*^9, 3.7669278482157297`*^9}, 
   3.7669286569861765`*^9, 3.766969537732936*^9, 3.766970029095761*^9, 
   3.7669779622386093`*^9, 3.7669806726670227`*^9, 3.7669810180981865`*^9, 
   3.7670241370082693`*^9},
 CellLabel->"Out[74]=",ExpressionUUID->"efba1acc-af07-4533-8261-c830203d18bf"]
}, Open  ]],

Cell[TextData[{
 "These two values make ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", "x"], "-", "x"}], TraditionalForm]],ExpressionUUID->
  "b57b2fe0-05b9-49df-84c4-b6609833ea75"],
 " equal to zero, this  makes  ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{
     FractionBox["1", "x"], "-", "x"}]], TraditionalForm]],ExpressionUUID->
  "28b813df-93b8-445b-930f-8ad929ddbea9"],
 " indeterminate which makes in turn, ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["3", "indeterminate"], TraditionalForm]],ExpressionUUID->
  "ddea811b-7ed5-4392-9ce4-c5a7d681ece4"],
 " as indeterminate. The points (-1) and (1)  are the discontinuity points \
found algebraically and they are confirmed by the graph of this function."
}], "Text",
 CellChangeTimes->{{3.766478508988986*^9, 3.766478589761389*^9}, {
   3.766478633745923*^9, 3.7664786847145643`*^9}, {3.766904739366212*^9, 
   3.7669047636943398`*^9}, {3.7669287247296023`*^9, 
   3.7669287353455477`*^9}, {3.766928781665165*^9, 3.76692890729064*^9}, {
   3.7669289576509285`*^9, 3.7669289756506915`*^9}, {3.7669700619018955`*^9, 
   3.7669700687631755`*^9}, {3.766970100971257*^9, 3.76697011277064*^9}, {
   3.767018492703971*^9, 3.767018531457735*^9}, 
   3.7670199212594805`*^9},ExpressionUUID->"31a355f2-c3ed-4aec-ad3b-\
8b19e4f96035"],

Cell["\<\
 Upper and lower limits  in the neighborhood of these points, will show the \
type of discontinuity of this function.\
\>", "Text",
 CellChangeTimes->{
  3.7664770886491723`*^9, {3.766928992811904*^9, 3.76692902677457*^9}, {
   3.7669701389269753`*^9, 
   3.7669701394894238`*^9}},ExpressionUUID->"db1f0e80-8140-4e93-990c-\
db37950a2d23"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"x", "\[Rule]", 
      RowBox[{
       RowBox[{"-", "1"}], "-", "0"}]}]}], "]"}], ",", 
   RowBox[{"Limit", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"x", "\[Rule]", 
      RowBox[{
       RowBox[{"-", "1"}], "+", "0"}]}]}], "]"}]}], "}"}]], "Input",
 CellChangeTimes->{{3.7661919192491617`*^9, 3.7661919631117425`*^9}, {
   3.766192005380896*^9, 3.7661920494471426`*^9}, 3.76647871700386*^9, {
   3.7669064384524527`*^9, 3.766906473110712*^9}, {3.766907055560968*^9, 
   3.7669070822877445`*^9}, {3.7669072421057177`*^9, 3.7669072466481404`*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"9f9a4924-49c4-435d-9b9c-473e6c5d008b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"Indeterminate", ",", "Indeterminate"}], "}"}]], "Output",
