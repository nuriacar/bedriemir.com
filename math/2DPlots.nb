Cell[TextData[{
 "Plot y = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "6f915213-e9ad-48ac-b2a2-bd9ae97f66de"],
 " + ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "5"], TraditionalForm]],
  FormatType->"TraditionalForm",ExpressionUUID->
  "7ae914f2-13ee-402d-b698-64081c541a8c"],
 " where the domain of x will be [-10 , 10]. (University of Texas in Austin) "
}], "Text",
