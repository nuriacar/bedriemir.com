 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7513002887299223`*^9, 3.751300331579305*^9}, {
   3.7513049924841785`*^9, 3.7513050212523017`*^9}, {3.7513050884729013`*^9, 
   3.7513051061651373`*^9}},ExpressionUUID->"ef076b03-4277-4425-9bdc-\
a030cebe664f"],

Cell["De Morgan Laws for Sets,", "Text",
 CellChangeTimes->{{3.751300346141653*^9, 3.751300372004609*^9}, {
  3.7513050343077416`*^9, 3.7513050378266306`*^9}, {3.751305117416947*^9, 
  3.7513051218575907`*^9}},ExpressionUUID->"d9fbdc5e-cdfa-44af-80a0-\
b18f1bd7ec4f"],

Cell["(A \[Union] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \[Intersection] \
B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
  3.750952288053732*^9, {3.7509528255462604`*^9, 3.750952868219779*^9}, {
   3.7513050555071497`*^9, 3.7513050626400023`*^9}, {3.751305143238707*^9, 
   3.7513051476580267`*^9}},ExpressionUUID->"ff6a4206-58dc-4df2-a10f-\
bccf37c7eccd"],

Cell["(A \[Intersection] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \[Union] \
B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
  3.750952288053732*^9, {3.7509528255462604`*^9, 3.750952868219779*^9}, {
   3.7513050555071497`*^9, 
   3.7513050626400023`*^9}},ExpressionUUID->"21416da7-8e12-4149-b5f9-\
8dc9fe7da1d9"],

Cell["\<\
Are valid theorems independent of compositions of both A and B.\
\>", "Text",
 CellChangeTimes->{{3.751300405751734*^9, 3.751300442286401*^9}, {
  3.751305159444944*^9, 
  3.751305216093029*^9}},ExpressionUUID->"56667e1d-728b-4c47-9154-\
3d2865bd0eed"],

Cell["\<\
Discleamer : I hereby certify that no other proofs is consulted before \
setting up this proof and this is purely an original work. But it is possible \
that similar proofs may be given elsewhere without the knowledge of the \
author.\
\>", "Text",
 CellChangeTimes->{{3.7509573893748784`*^9, 3.75095755316897*^9}, {
  3.75095760212648*^9, 3.75095766429889*^9}, {3.7513072454057045`*^9, 
  3.7513072509702115`*^9}},ExpressionUUID->"39ac56f6-a8b2-42f0-ba5c-\
8147b43c8ac5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numerical Evaluations by the Application of the Mathematica", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.751305965474037*^9, 3.751306024548786*^9}, {
   3.751306832617908*^9, 
   3.7513068439852877`*^9}},ExpressionUUID->"c3806c60-5fab-4967-b452-\
b000f436f700"],

Cell["\<\
Mathematica (11.3) is used to investigate numerical evaluations of both De \
Morgan Laws for sets. For the mathematical point of view the logical proofs \
are essential and numerical correspondences are futile. But numerical \
examples are useful for better understanding mathematical results of the \
methods applied in the logical proofs. These numerical results are only given \
here under these auspices.\
\>", "Text",
 CellChangeTimes->{{3.751306035583831*^9, 3.751306157978003*^9}, {
  3.751306428837366*^9, 3.75130672436061*^9}, {3.7513068028403635`*^9, 
  3.751306812195421*^9}, {3.751306858903383*^9, 
  3.7513068907500744`*^9}},ExpressionUUID->"28d04ab2-57ed-4205-8a92-\
6888c9f8726f"]
}, Open  ]],

