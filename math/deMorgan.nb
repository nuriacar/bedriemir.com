Notebook[{

Cell[CellGroupData[{
Cell["De Morgan Laws for Sets", "Chapter",
 CellChangeTimes->{{3.75095203263815*^9, 3.7509520479633503`*^9}, 
   3.751005030816527*^9, 
   3.7511933797237897`*^9},ExpressionUUID->"70ec524b-e0f2-4068-ad73-\
0dfbd84aa900"],

Cell["De Morgan Laws for sets are stated as,", "Text",
 CellChangeTimes->{{3.751305344741048*^9, 3.751305369520851*^9}, {
  3.751305815883999*^9, 
  3.751305816560246*^9}},ExpressionUUID->"35069c1d-87c8-4e4a-ab19-\
f70f25187ef7"],

Cell["(1)       (A \[Union] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \
\[Intersection] B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
  3.750952288053732*^9, {3.7509528255462604`*^9, 3.750952868219779*^9}, {
   3.7513054360592976`*^9, 
   3.7513054401506653`*^9}},ExpressionUUID->"a3a9c058-3c01-4021-893b-\
b71563d350d8"],

Cell["(2)       (A \[Intersection] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \
\[Union] B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
  3.750952288053732*^9, {3.7509528255462604`*^9, 3.750952868219779*^9}, {
   3.7513054360592976`*^9, 
   3.751305481199416*^9}},ExpressionUUID->"a2d2b516-f373-4a8c-9fc2-\
4d64e90e939a"],

Cell["\<\
We will seek the validity of these theorems by investigating case by case of \
the relative compositions of the acting sets A and B,\
\>", "Text",
 CellChangeTimes->{{3.7513055047544146`*^9, 
  3.751305636355674*^9}},ExpressionUUID->"a7970801-7541-41a2-949e-\
44ff0c8a163f"],

Cell["\<\
The sets A and B may be either equal , disjoint or one is a proper subset of \
the other. No other configuration is possible.\
\>", "Text",
 CellChangeTimes->{{3.7512760705587606`*^9, 3.7512761567940516`*^9}, {
  3.7512761995668287`*^9, 3.7512762086092043`*^9}, {3.751276252391599*^9, 
  3.751276322497713*^9}, {3.75130571932738*^9, 
  3.7513057723607845`*^9}},ExpressionUUID->"14bb9d78-b4be-45c1-ac3a-\
2e47fa5e99db"],

Cell["\<\
We will always use the union of the sets A and B for the universe of \
discourse.\
\>", "Text",
 CellChangeTimes->{{3.751276362907675*^9, 3.751276426890576*^9}, {
  3.751305278078019*^9, 
  3.7513052804348445`*^9}},ExpressionUUID->"7253ae98-957d-4bfe-b797-\
2af82d269022"]
}, Open  ]],

Cell["1 - First De Morgan Law", "Chapter",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7509520606450577`*^9, 3.750952074549412*^9}, 
   3.751005037251792*^9, 3.7511933797550287`*^9, {3.7513004849841614`*^9, 
   3.7513004865343556`*^9}},ExpressionUUID->"0543877f-d661-49cb-8436-\
dd13ce5504c7"],

Cell[CellGroupData[{

Cell["Case 1 : A = B", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7512764578599463`*^9, 
   3.7512764718436584`*^9}},ExpressionUUID->"ab0fdd17-e359-422e-8ccb-\
4496e06e4611"],

Cell["\<\
In this case, (A \[Union] B) = A = B   ,  (A \[Union] B)\[CloseCurlyQuote] = \
\[EmptySet]      ,       A\[CloseCurlyQuote] = B\[CloseCurlyQuote] = \
\[EmptySet]    ,       A\[CloseCurlyQuote] \[Intersection] \
B\[CloseCurlyQuote] = \[EmptySet] \[Intersection] \[EmptySet] = \[EmptySet]\
\>", "Text",
 CellChangeTimes->{{3.751276479824811*^9, 3.7512764919522376`*^9}, {
  3.7512765437800655`*^9, 3.751276659559049*^9}, {3.751276689845788*^9, 
  3.751276690986392*^9}, {3.7512767795902576`*^9, 3.7512768397958555`*^9}, {
  3.7512993704109154`*^9, 
  3.751299400255252*^9}},ExpressionUUID->"bec64fec-ab72-424c-a0b3-\
9a8ae2828e8e"],

Cell["Finally,", "Text",
 CellChangeTimes->{{3.7512767364819336`*^9, 
  3.7512767422323303`*^9}},ExpressionUUID->"07292b81-14e9-4138-945c-\
4162d03ebf8b"],

Cell["\[EmptySet] = \[EmptySet]        Q.E.D.", "Text",
 CellChangeTimes->{{3.75127675696832*^9, 3.751276770482003*^9}, {
  3.7512768486224203`*^9, 
  3.7512768542342186`*^9}},ExpressionUUID->"163111b1-4efb-49d1-a5fc-\
c57ba7e77f79"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Case 2 : A and B are Disjoint", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7512764578599463`*^9, 3.7512764718436584`*^9}, {
   3.751277256295848*^9, 3.751277258249406*^9}, {3.7512978961266313`*^9, 
   3.751297930997569*^9}, {3.7512981312616663`*^9, 3.7512981441907496`*^9}, {
   3.751347090144071*^9, 
   3.7513470955843716`*^9}},ExpressionUUID->"a5ffbed0-593a-4f95-8087-\
9842252a5ec7"],

Cell["\<\
In this case, (A \[Union] B) = U   ,   (A \[Union] B)\[CloseCurlyQuote] =  U\
\[CloseCurlyQuote] = \[EmptySet]   ,     A\[CloseCurlyQuote] = B   ,   B\
\[CloseCurlyQuote] = A ,          A\[CloseCurlyQuote] \[Intersection] B\
\[CloseCurlyQuote] = A \[Intersection] B = \[EmptySet]\
\>", "Text",
 CellChangeTimes->{{3.751276479824811*^9, 3.7512764919522376`*^9}, {
  3.7512765437800655`*^9, 3.751276659559049*^9}, {3.751276689845788*^9, 
  3.751276690986392*^9}, {3.7512767795902576`*^9, 3.7512768397958555`*^9}, {
  3.751299055928481*^9, 3.751299167559599*^9}, {3.751299218015006*^9, 
  3.751299249057083*^9}, {3.751331700265312*^9, 
  3.751331709157526*^9}},ExpressionUUID->"b447f899-b761-4bf8-b769-\
47bbf9734fc4"],

Cell["Finally,", "Text",
 CellChangeTimes->{{3.7512767364819336`*^9, 
  3.7512767422323303`*^9}},ExpressionUUID->"b99e343c-a63c-4c4a-beea-\
6ccb23dcb69f"],

Cell["\[EmptySet] = \[EmptySet]        Q.E.D.", "Text",
 CellChangeTimes->{{3.75127675696832*^9, 3.751276770482003*^9}, {
  3.7512768486224203`*^9, 
  3.7512768542342186`*^9}},ExpressionUUID->"736cd920-1990-45ca-a36d-\
7085d22795ac"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Case 2 : A \[Subset] B (A is a Proper Subset of B)", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7512764578599463`*^9, 3.7512764718436584`*^9}, {
   3.751277256295848*^9, 3.751277258249406*^9}, {3.7512978961266313`*^9, 
   3.751297930997569*^9}, {3.7512981312616663`*^9, 3.7512981441907496`*^9}, {
   3.7512994553669395`*^9, 3.7512994634998984`*^9}, {3.751300002054747*^9, 
   3.7513000349189157`*^9}},ExpressionUUID->"41895fc3-dd50-403b-bf06-\
2b434c1bc70f"],

Cell["\<\
In this case, (A \[Union] B) = U = B   ,   (A \[Union] B)\[CloseCurlyQuote] = \
 U\[CloseCurlyQuote] = \[EmptySet]   ,     A\[CloseCurlyQuote] = (B - A)  ,   \
B\[CloseCurlyQuote] = \[EmptySet] , 
A\[CloseCurlyQuote] \[Intersection] B\[CloseCurlyQuote] = ((B-A)  \
\[Intersection]  \[EmptySet]) = \[EmptySet]\
\>", "Text",
 CellChangeTimes->{{3.751276479824811*^9, 3.7512764919522376`*^9}, {
   3.7512765437800655`*^9, 3.751276659559049*^9}, {3.751276689845788*^9, 
   3.751276690986392*^9}, {3.7512767795902576`*^9, 3.7512768397958555`*^9}, {
   3.751299055928481*^9, 3.751299167559599*^9}, {3.751299218015006*^9, 
   3.751299249057083*^9}, {3.751300124923442*^9, 3.751300250604139*^9}, 
   3.751304357957903*^9, {3.7513044879216003`*^9, 3.7513044995907135`*^9}, {
   3.7513046741193333`*^9, 3.7513046971866527`*^9}, {3.7513442593637667`*^9, 
   3.751344264327489*^9}},ExpressionUUID->"3f023412-2568-4896-b817-\
b21934081fa6"],

Cell["Finally,", "Text",
 CellChangeTimes->{{3.7512767364819336`*^9, 
  3.7512767422323303`*^9}},ExpressionUUID->"2e93189a-a229-48a2-8375-\
1a89747acc5f"],

Cell["\[EmptySet] = \[EmptySet]        Q.E.D.", "Text",
 CellChangeTimes->{{3.75127675696832*^9, 3.751276770482003*^9}, {
  3.7512768486224203`*^9, 
  3.7512768542342186`*^9}},ExpressionUUID->"1df46864-fe34-47b8-8ae7-\
4aa12718e61f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Result for The First De Morgan Law", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7513002887299223`*^9, 
   3.751300331579305*^9}},ExpressionUUID->"e8fc08b5-aa67-4e4c-bb1e-\
4b8e3ec0cbb6"],

Cell["First De Morgan Law for Sets,", "Text",
 CellChangeTimes->{{3.751300346141653*^9, 
  3.751300372004609*^9}},ExpressionUUID->"719bfe5f-1008-4d56-9117-\
161b4adb7138"],

Cell["(A \[Union] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \[Intersection] \
B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
  3.750952288053732*^9, {3.7509528255462604`*^9, 
   3.750952868219779*^9}},ExpressionUUID->"2cd7e941-07e6-494c-a42b-\
1c0c7a19f389"],

Cell["Is a valid theorem for all compositions of both A and B.", "Text",
 CellChangeTimes->{{3.751300405751734*^9, 3.751300442286401*^9}, {
  3.7513052606006737`*^9, 
  3.7513052619969826`*^9}},ExpressionUUID->"9e253a7e-1aa2-4e8c-91f5-\
3e871defc3d6"],

Cell[CellGroupData[{

Cell["2 - Second De Morgan Law", "Chapter",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7509520606450577`*^9, 3.750952074549412*^9}, 
   3.751005037251792*^9, 3.7511933797550287`*^9, {3.7513004849841614`*^9, 
   3.7513004865343556`*^9}, {3.7513005192777925`*^9, 
   3.751300526616233*^9}},ExpressionUUID->"dd0e7f14-0321-4adb-a950-\
cba78d868037"],

Cell["Second De Morgan Law is stated as,", "Text",
 CellChangeTimes->{{3.7512435954469423`*^9, 
  3.751243647655843*^9}},ExpressionUUID->"8c0fb510-c280-4f69-a2b4-\
f4893be56676"],

Cell["(A \[Intersection] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \[Union] \
B\[CloseCurlyQuote] ", "Text",
 CellChangeTimes->{{3.7512436723728933`*^9, 3.7512437127160707`*^9}, 
   3.7512437509027843`*^9},ExpressionUUID->"6be2ce3a-e42a-40d4-9f9f-\
63e725207579"],

Cell["\<\
When A \[Union] B is taken as the universe of discourse in an arbitrary \
length, the intersection of A and B results with a set which the composition \
is dependent of the relative compositions of the sets under consideration.\
\>", "Text",
 CellChangeTimes->{{3.7512437793099504`*^9, 3.751244099717984*^9}, {
  3.7513342919061823`*^9, 3.7513343078114595`*^9}, {3.751334599984017*^9, 
  3.751334603126831*^9}},ExpressionUUID->"b86c2a94-c404-4fee-915c-\
65d0239b8ab2"],

Cell["\<\
We will check the logical validiy of this rule, case by case, until all the \
possible relative configurations of the sets under consideration are all \
depleted. \
\>", "Text",
 CellChangeTimes->{{3.751334405149524*^9, 
  3.751334569985606*^9}},ExpressionUUID->"b4c6f5c7-23fe-4150-b503-\
1068f40370df"],

Cell[CellGroupData[{

Cell["Case 1 : A = B", "Subsubsection",
 CellChangeTimes->{{3.751244900402768*^9, 
  3.7512449164846544`*^9}},ExpressionUUID->"2862f6cc-06c8-4091-8f06-\
b007959a3583"],

Cell["In this case,  A \[Intersection] B = A = B", "Text",
 CellChangeTimes->{{3.7512449744129195`*^9, 3.751245021325448*^9}, {
   3.75124507306*^9, 3.751245081249197*^9}, 3.7512453101861515`*^9, {
   3.7512454502000895`*^9, 3.751245514716092*^9}, 
   3.751245630016039*^9},ExpressionUUID->"e4f62e1a-ed94-428f-89c3-\
74699cefe303"],

Cell["( A \[Intersection] B)\[CloseCurlyQuote] = \[EmptySet] ,  ", "Text",
 CellChangeTimes->{{3.751245534201068*^9, 3.7512455527627077`*^9}, {
   3.751245611195187*^9, 3.7512457094032927`*^9}, {3.7512458667773876`*^9, 
   3.7512458777000766`*^9}, 3.751249159310986*^9, 3.7512492107935944`*^9, 
   3.751249247764288*^9},ExpressionUUID->"f539b4ae-9fe1-4fe5-a4fd-\
355139dee975"],

Cell["A\[CloseCurlyQuote] = \[EmptySet] ,   B\[CloseCurlyQuote] = \[EmptySet] \
 ,   A\[CloseCurlyQuote] \[Union] B \[OpenCurlyQuote]  = \[EmptySet]", "Text",
 CellChangeTimes->{{3.751245734592103*^9, 3.751245767105553*^9}, {
  3.7512458014873276`*^9, 3.751245856702794*^9}, {3.7512492923151207`*^9, 
  3.751249325235403*^9}},ExpressionUUID->"980498bf-b99c-44cb-b689-\
4dd3a58922ad"],

Cell["Therefore,", "Text",
 CellChangeTimes->{{3.7512458981408577`*^9, 
  3.7512459111878314`*^9}},ExpressionUUID->"0a8e6bb6-5260-409d-baff-\
2d03c5a8d478"],

Cell[TextData[StyleBox["(A \[Intersection] B)\[CloseCurlyQuote] = A\
\[CloseCurlyQuote] \[Union] B\[CloseCurlyQuote]  =  \[EmptySet]       Q.E.D.\n\
",
 FontColor->RGBColor[0.5411764705882353, 0., 0.]]], "Text",
 CellChangeTimes->{
  3.751245950952292*^9, {3.751245987562132*^9, 3.7512460025449915`*^9}, 
   3.751246122406712*^9, {3.7512493323881197`*^9, 
   3.7512493365454087`*^9}},ExpressionUUID->"c8166690-e5c4-46a1-a358-\
dd33aa94df8b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Case 2 : A and B are Disjoint Sets", "Subsubsection",
 CellChangeTimes->{{3.751244900402768*^9, 3.7512449164846544`*^9}, {
  3.751246154981511*^9, 3.751246213468341*^9}, {3.7512463097649727`*^9, 
  3.751246311624653*^9}},ExpressionUUID->"d0406220-9971-4a79-8251-\
8079a490596e"],

Cell["In this case,  (A \[Intersection] B)  = \[EmptySet]", "Text",
 CellChangeTimes->{{3.7512449744129195`*^9, 3.751245021325448*^9}, {
   3.75124507306*^9, 3.751245081249197*^9}, 3.7512453101861515`*^9, {
   3.7512454502000895`*^9, 3.751245514716092*^9}, 3.751245630016039*^9, {
   3.7512463459271784`*^9, 3.7512463908256493`*^9}, {3.7512494453436017`*^9, 
   3.751249461310275*^9}},ExpressionUUID->"80e20165-3cfc-4f2e-9f60-\
f22511ad7616"],

Cell["( A \[Intersection] B)\[CloseCurlyQuote] = \
\[EmptySet]\[CloseCurlyQuote] = U (Universal Set)", "Text",
 CellChangeTimes->{{3.751245534201068*^9, 3.7512455527627077`*^9}, {
  3.751245611195187*^9, 3.7512457094032927`*^9}, {3.7512458667773876`*^9, 
  3.7512458777000766`*^9}, {3.7512494872812433`*^9, 
  3.7512495028420854`*^9}},ExpressionUUID->"7b03d34a-3f67-4b41-8b06-\
8d07b9f9bdda"],

Cell["A' = B ,  B\[CloseCurlyQuote] = A ,   (A\[CloseCurlyQuote] \[Union] B\
\[CloseCurlyQuote]) = (A \[Union] B) = U", "Text",
 CellChangeTimes->{{3.751249527341185*^9, 3.7512495328897223`*^9}, {
  3.751249576248353*^9, 
  3.751249674701644*^9}},ExpressionUUID->"0455f76a-14e7-46db-a209-\
cbeea94f1709"],

Cell["Therefore,", "Text",
 CellChangeTimes->{{3.7512458981408577`*^9, 
  3.7512459111878314`*^9}},ExpressionUUID->"f4effcf3-d796-42fc-af8e-\
ba64acaf09f4"],

Cell[TextData[StyleBox["(A \[Intersection] B)\[CloseCurlyQuote] = A\
\[CloseCurlyQuote] \[Union] B\[CloseCurlyQuote]  =  U       Q.E.D.\n",
 FontColor->RGBColor[0.5411764705882353, 0., 0.]]], "Text",
 CellChangeTimes->{
  3.751245950952292*^9, {3.751245987562132*^9, 3.7512460025449915`*^9}, 
   3.751246122406712*^9, {3.7512493323881197`*^9, 3.7512493365454087`*^9}, 
   3.7512497148575277`*^9},ExpressionUUID->"1fe90932-2f6e-4e66-b50c-\
0355cc1bba4f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Case 3 : A is a Proper Set of B (A \[Subset] B)", "Subsubsection",
 CellChangeTimes->{{3.751244900402768*^9, 3.7512449164846544`*^9}, {
   3.751246154981511*^9, 3.751246213468341*^9}, {3.7512463097649727`*^9, 
   3.751246311624653*^9}, {3.751263397528516*^9, 3.7512634415099125`*^9}, {
   3.751263655875219*^9, 3.7512636599495707`*^9}, 
   3.751263751590807*^9},ExpressionUUID->"52d0a73e-d6ff-4eb6-8d8a-\
20b9f3c5faec"],

Cell["In this case,  (A \[Intersection] B)  = A    ,     (A \[Intersection] \
B)\[CloseCurlyQuote]  =  (B - A)", "Text",
 CellChangeTimes->{{3.7512449744129195`*^9, 3.751245021325448*^9}, {
   3.75124507306*^9, 3.751245081249197*^9}, 3.7512453101861515`*^9, {
   3.7512454502000895`*^9, 3.751245514716092*^9}, 3.751245630016039*^9, {
   3.7512463459271784`*^9, 3.7512463908256493`*^9}, {3.7512494453436017`*^9, 
   3.751249461310275*^9}, {3.7512638177041006`*^9, 3.751263820048042*^9}, {
   3.751263889840417*^9, 3.751263890981398*^9}, {3.7512639507944803`*^9, 
   3.7512639561100616`*^9}, {3.7512639890130043`*^9, 
   3.7512640377540655`*^9}, {3.751334827313399*^9, 
   3.75133485130031*^9}},ExpressionUUID->"b270235c-82f2-4508-846f-\
a26c26d1956c"],

Cell["A\[CloseCurlyQuote] = (B - A)    ,   B\[CloseCurlyQuote] = \[EmptySet]  \
 ,   A\[CloseCurlyQuote] \[Union] B\[CloseCurlyQuote] = (B - A) ", "Text",
 CellChangeTimes->{{3.7512647613703337`*^9, 
  3.751264914156229*^9}},ExpressionUUID->"fa7d7d90-d03a-490a-b17b-\
56bdafffc76f"],

Cell["Therefore,", "Text",
 CellChangeTimes->{{3.7512458981408577`*^9, 
  3.7512459111878314`*^9}},ExpressionUUID->"90321c2c-bc05-4585-b4cd-\
a3a002e40148"],

Cell[TextData[StyleBox["(A \[Intersection] B)\[CloseCurlyQuote] = A\
\[CloseCurlyQuote] \[Union] B\[CloseCurlyQuote]  =  (B-A)       Q.E.D.\n",
 FontColor->RGBColor[0.5411764705882353, 0., 0.]]], "Text",
 CellChangeTimes->{
  3.751245950952292*^9, {3.751245987562132*^9, 3.7512460025449915`*^9}, 
   3.751246122406712*^9, {3.7512493323881197`*^9, 3.7512493365454087`*^9}, 
   3.7512497148575277`*^9, {3.7512649547477083`*^9, 
   3.7512649600611105`*^9}},ExpressionUUID->"680a4526-38a5-4b57-a61c-\
9129b4c7044b"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["General Result for The Second De Morgan Law for Sets", "Title",
 CellChangeTimes->{
  3.6312477431605005`*^9, {3.7513002887299223`*^9, 3.751300331579305*^9}, {
   3.7513049924841785`*^9, 
   3.7513050212523017`*^9}},ExpressionUUID->"d990936e-3695-4dc8-a3b0-\
5d75818c94a9"],

Cell["Second De Morgan Law for Sets,", "Text",
 CellChangeTimes->{{3.751300346141653*^9, 3.751300372004609*^9}, {
  3.7513050343077416`*^9, 
  3.7513050378266306`*^9}},ExpressionUUID->"66e2dd12-b41f-4bdc-9ab3-\
8f1b068187f4"],

Cell["(A \[Intersection] B)\[CloseCurlyQuote] = A\[CloseCurlyQuote] \[Union] \
B\[CloseCurlyQuote]", "Text",
 CellChangeTimes->{
