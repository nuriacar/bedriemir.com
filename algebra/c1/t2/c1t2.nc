Cell[TextData[{
 "Bu \:015fekilden de g\[ODoubleDot]r\[UDoubleDot]lebildi\:011fi gibi, h ve k \
do\:011frular\[DotlessI], g do\:011frusu ile \[Alpha] ve \[Beta] a\[CCedilla]\
\[DotlessI]lar\[DotlessI] ile kesilmektedir.\nBurada, \[Alpha] = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["50", "o"], TraditionalForm]]],
 " , \[Beta] = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["110", "o"], TraditionalForm]]],
 " , \[Alpha] + \[Beta] = 110 + 50 = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["160", "o"], TraditionalForm]]],
 " dolay\[DotlessI]s\[DotlessI] ile (\[Alpha] + \[Beta]) < (90 x 2 = ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["180", "o"], TraditionalForm]]],
 ") dir. Bu durumda, (\[Alpha] + \[Beta]) < (",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["180", "o"], TraditionalForm]]],
 ") oldu\:011fundan, h ve k e\:011frileri yeterince uzat\[DotlessI]ld\
\[DotlessI]\:011f\[DotlessI]nda , 5 inci postulatum\[CloseCurlyQuote]a g\
\[ODoubleDot]re, \[Alpha] ve \[Beta] a\[CCedilla]\[DotlessI]lar\[DotlessI]n\
\[DotlessI]n bulundu\:011fu tarafta kesi\:015fmeleri gerekir. Bunun ger\
\[CCedilla]ekle\:015fti\:011fi, do\:011frular\[DotlessI]n S \
noktas\[DotlessI]nda kesi\:015fmesi ile belirlenir."
}], "Text"],

Cell[TextData[{
 "Tarih boyunca, paralel postulatum zor anla\:015f\[DotlessI]l\[DotlessI]r \
oldu\:011fundan e\:015fde\:011fer ifadeler olu\:015fturulmaya \[CCedilla]al\
\[DotlessI]\:015f\[DotlessI]lm\[DotlessI]\:015ft\[DotlessI]r. Bunlardan en \
\[UDoubleDot]nl\[UDoubleDot]s\[UDoubleDot], ",
 ButtonBox["1795 de",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://en.wikipedia.org/wiki/Parallel_postulate"], None},
  ButtonNote->"http://en.wikipedia.org/wiki/Parallel_postulate"],
 " \:0130sko\[CCedilla] matematik\[CCedilla]i, ",
 ButtonBox["John Playfair",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://en.wikipedia.org/wiki/John_Playfair"], None},
  ButtonNote->"http://en.wikipedia.org/wiki/John_Playfair"],
 "\[CloseCurlyQuote]in ileri s\[UDoubleDot]rd\[UDoubleDot]\:011f\[UDoubleDot] \
",
 ButtonBox["Playfair aksiyomu",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://en.wikipedia.org/wiki/Playfair%27s_axiom"], None},
  ButtonNote->"http://en.wikipedia.org/wiki/Playfair%27s_axiom"],
 "\[CloseCurlyQuote]dur. Playfair aksiyomu,"
}], "Text"],

Cell[TextData[StyleBox["Bir d\[UDoubleDot]zlemde, bir do\:011fru ve onun \
\[UDoubleDot]zerinde olmayan bir nokta tan\[DotlessI]mlan\[DotlessI]rsa, bu \
noktadan o do\:011fruya sadece bir tek paralel \[CCedilla]izilebilir",
 FontSlant->"Italic"]], "Text"],

Cell["\<\
olarak ifade edilmi\:015ftir. Playfair aksiyomu, \
a\:015fa\:011f\[DotlessI]daki \:015fekilde g\[ODoubleDot]r\[UDoubleDot]nt\
\[UDoubleDot]lenebilir:\
