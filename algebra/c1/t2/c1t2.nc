Cell["\<\
\:015eekillerden de g\[ODoubleDot]r\[UDoubleDot]ld\[UDoubleDot]\:011f\
\[UDoubleDot] gibi bir do\:011fruya belirli ve do\:011fru i\[CCedilla]inde \
olmayan bir noktadan sadece bir tek parelel \[CCedilla]izilebilmektedir.\
\>", "Text"],

Cell[TextData[{
 "Playfair postulatumu Euclides\[CloseCurlyQuote]in paralel postulat\
\[DotlessI] ile ayn\[DotlessI] s\[ODoubleDot]ylemi i\[CCedilla]ermez, yine de \
matematik mant\[DotlessI]k a\[CCedilla]\[DotlessI]s\[DotlessI]ndan, e\:011fer \
paralel olarak kesi\:015fmeyen do\:011frular ama\[CCedilla]lan\[DotlessI]rsa, \
Euclides\[CloseCurlyQuote]in paralel postulat\[DotlessI] ile \
e\:015fde\:011fer olarak de\:011ferlendirilmi\:015ftir. Playfair postulat\
\[DotlessI], okul \[CCedilla]a\:011f\[DotlessI]ndaki \
\[ODoubleDot]\:011frencilere, anla\:015f\[DotlessI]lmas\[DotlessI] zor olan \
Euclides\[CloseCurlyQuote]in s\[ODoubleDot]ylemi yan\[DotlessI]nda, daha \
kolay anla\:015f\[DotlessI]l\[DotlessI]r bir ifade \:015fekli \
getirmi\:015ftir. Bizim lisedede de (",
 ButtonBox["GSL",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.gsl.gsu.edu.tr/"], None},
  ButtonNote->"http://www.gsl.gsu.edu.tr/"],
 ") Euclides\[CloseCurlyQuote]in paralel postulat\[DotlessI]n\[DotlessI] do\
\:011frudan vermek yerine daha kolay anla\:015f\[DotlessI]labilen Playfair \
postulat\[DotlessI] verilmi\:015fti."
}], "Text"],

Cell["\<\
Euclides' in paralel postulat\[DotlessI]n\[DotlessI]n s\[ODoubleDot]ylemi, \
daha bir \[CCedilla]ok \:015fekilde belirtilmi\:015ftir. Bunlar\[DotlessI]n \
bilinmesi yararl\[DotlessI] olacakt\[DotlessI]r.\
\>", "Text"],

Cell[CellGroupData[{

Cell["\<\
 1 - Bir do\:011fruya, d\[DotlessI]\:015f bir noktadan, sadece bir tek \
paralel \[CCedilla]izilebilir. (Playfair Aksiyomu)\
\>", "Item"],

Cell[TextData[{
 " 2 - Her \[UDoubleDot]\[CCedilla]genin i\[CCedilla] \
a\[CCedilla]\[DotlessI]lar\[DotlessI]n\[DotlessI]n toplam\[DotlessI] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["180", "o"], TraditionalForm]]],
 " dir. (\[UDoubleDot]\[CCedilla]gen postulatumu)"
}], "Item"],

Cell[TextData[{
 " 3 - A\[CCedilla]\[DotlessI]lar\[DotlessI]n\[DotlessI]n toplam\[DotlessI] ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["180", "o"], TraditionalForm]]],
 " olan bir \[UDoubleDot]\[CCedilla]gen vard\[DotlessI]r."
}], "Item"],

Cell[" 4 - Her \[UDoubleDot]\[CCedilla]genin a\[CCedilla]\[DotlessI]lar\
\[DotlessI]n\[DotlessI]n toplam\[DotlessI] ayn\[DotlessI]d\[DotlessI]r.", \
"Item"],

Cell["\<\
 5 - Bir \[CCedilla]ift benzer (similar) fakat e\:015fit (congruent) olmayan \
\[UDoubleDot]\[CCedilla]gen vard\[DotlessI]r.\
\>", "Item"],

Cell[" 6 - Her \[UDoubleDot]\[CCedilla]gen bir \[CCedilla]ember \
i\[CCedilla]ine al\[DotlessI]nabilir.", "Item"],

Cell["\<\
 7 - E\:011fer bir d\[ODoubleDot]rgenin \[UDoubleDot]\[CCedilla] a\[CCedilla]\
\[DotlessI]s\[DotlessI] da dik a\[CCedilla]\[DotlessI] ise, d\[ODoubleDot]rd\
\[UDoubleDot]nc\[UDoubleDot]s\[UDoubleDot] de dik a\[CCedilla]\[DotlessI]d\
\[DotlessI]r.\
\>", "Item"],

Cell[" 8 - T\[UDoubleDot]m a\[CCedilla]\[DotlessI]lar\[DotlessI] dik a\
\[CCedilla]\[DotlessI] olan bir d\[ODoubleDot]rtgen vard\[DotlessI]r.", "Item"],

Cell[" 9 - Birbirleri ile sabit aral\[DotlessI]kta olan iki do\:011fru vard\
\[DotlessI]r.", "Item"],

Cell["\<\
 10 - Bir \[UDoubleDot]\[CCedilla]\[UDoubleDot]nc\[UDoubleDot]s\[UDoubleDot] \
ile paralel olan iki do\:011fru, birbirleri ile de paraleldir.\
\>", "Item"],

Cell["\<\
 11 - Bir dik \[UDoubleDot]\[CCedilla]gende, hipoten\[UDoubleDot]s\
\[UDoubleDot]n karesi, di\:011fer iki kenar\[DotlessI]n karelerinin toplam\
